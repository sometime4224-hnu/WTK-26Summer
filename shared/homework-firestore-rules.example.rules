rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /homeworkAssignments/{assignmentId}/submissions/{submissionId} {
      allow read: if isTeacher();
      allow delete: if false;
      allow create: if isValidSubmission(assignmentId);
      allow update: if isValidSubmission(assignmentId)
        && resource.data.anonymousUid == request.auth.uid
        && resource.data.assignmentId == assignmentId
        && resource.data.signatureHash == request.resource.data.signatureHash;
    }

    function isTeacher() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "YOUR_TEACHER_EMAIL@example.com"
        ];
    }

    function isValidSubmission(assignmentId) {
      return request.auth != null
        && request.resource.data.assignmentId == assignmentId
        && request.resource.data.anonymousUid == request.auth.uid
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() >= 1
        && request.resource.data.studentName.size() <= 40
        && request.resource.data.completed == true
        && request.resource.data.score is int
        && request.resource.data.percent is int
        && request.resource.data.percent >= 0
        && request.resource.data.percent <= 100
        && request.resource.data.correctQuestions is list
        && request.resource.data.wrongQuestions is list
        && request.resource.data.questionResults is list
        && request.resource.data.clientSubmittedAt is string
        && request.resource.data.submittedAt is timestamp
        && (
          isC12ReviewSubmission(assignmentId)
          || isVocabGrammarMockSubmission(assignmentId)
          || isReview4Submission(assignmentId)
        );
    }

    function isC12ReviewSubmission(assignmentId) {
      return assignmentId == "c12-review-quiz-v1"
        && request.resource.data.chapter == "12"
        && request.resource.data.total == 24
        && request.resource.data.answered == 24
        && request.resource.data.score >= 0
        && request.resource.data.score <= 24
        && request.resource.data.questionResults.size() == 24;
    }

    function isReview4Assignment(assignmentId) {
      return assignmentId == "review4-reading-writing-v1";
    }

    function review4SectionId(assignmentId) {
      return "readingWriting";
    }

    function review4Total(assignmentId) {
      return 15;
    }

    function isReview4Submission(assignmentId) {
      return isReview4Assignment(assignmentId)
        && request.resource.data.chapter == "review4"
        && request.resource.data.sectionId == review4SectionId(assignmentId)
        && request.resource.data.sectionTitle is string
        && request.resource.data.total == review4Total(assignmentId)
        && request.resource.data.answered == review4Total(assignmentId)
        && request.resource.data.score >= 0
        && request.resource.data.score <= review4Total(assignmentId)
        && request.resource.data.questionResults.size() == review4Total(assignmentId);
    }

    function isVocabGrammarMockAssignment(assignmentId) {
      return assignmentId in [
        "vocab-grammar-mock-round1-v1",
        "vocab-grammar-mock-round2-v1",
        "vocab-grammar-mock-round1-ibt-v1",
        "vocab-grammar-mock-round2-ibt-v1",
        "vocab-grammar-mock-round3-ibt-v1",
        "vocab-grammar-mock-round4-ibt-v1",
        "vocab-grammar-mock-round3-v1",
        "vocab-grammar-mock-round4-v1",
        "vocab-grammar-mock-marathon30-v1"
      ];
    }

    function vocabGrammarMockTotal(assignmentId) {
      return assignmentId == "vocab-grammar-mock-round1-v1"
        || assignmentId == "vocab-grammar-mock-round1-ibt-v1"
        ? 26
        : assignmentId == "vocab-grammar-mock-marathon30-v1"
          ? 30
          : 25;
    }

    function isVocabGrammarMockSubmission(assignmentId) {
      return isVocabGrammarMockAssignment(assignmentId)
        && request.resource.data.chapter == "midterm-3b"
        && request.resource.data.roundId is string
        && request.resource.data.roundLabel is string
        && request.resource.data.total == vocabGrammarMockTotal(assignmentId)
        && request.resource.data.answered == vocabGrammarMockTotal(assignmentId)
        && request.resource.data.score >= 0
        && request.resource.data.score <= vocabGrammarMockTotal(assignmentId)
        && request.resource.data.questionResults.size() == vocabGrammarMockTotal(assignmentId);
    }
  }
}
