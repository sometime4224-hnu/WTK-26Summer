{
  "rules": {
    "typingParty": {
      "rooms": {
        "$roomCode": {
          ".read": "auth != null",
          ".write": "auth != null && ((!data.exists() && newData.child('meta/hostUid').val() === auth.uid) || (data.exists() && data.child('meta/hostUid').val() === auth.uid && !newData.exists()))",
          "meta": {
            ".write": "auth != null && data.parent().child('meta/hostUid').val() === auth.uid"
          },
          "rounds": {
            "$roundId": {
              ".write": "auth != null && data.parent().parent().child('meta/hostUid').val() === auth.uid"
            }
          },
          "players": {
            "$uid": {
              ".write": "auth != null && (auth.uid === $uid || data.parent().parent().child('meta/hostUid').val() === auth.uid)"
            }
          },
          "submissions": {
            "$roundId": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            }
          },
          "votes": {
            "$roundId": {
              "$category": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid"
                }
              }
            }
          },
          "progress": {
            "$runId": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            }
          },
          "world": {
            "state": {
              ".write": "auth != null && data.parent().parent().child('meta/hostUid').val() === auth.uid"
            },
            "players": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            },
            "progress": {
              "$stationId": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid"
                }
              }
            }
          },
          "groups": {
            "$groupId": {
              ".write": "auth != null && data.parent().child('meta/hostUid').val() === auth.uid"
            }
          },
          "groupSessions": {
            "$sessionId": {
              ".write": "auth != null && data.parent().child('meta/hostUid').val() === auth.uid"
            }
          },
          "drawings": {
            "$sessionId": {
              "$groupId": {
                "$drawingId": {
                  ".write": "auth != null && (root.child('typingParty/rooms/' + $roomCode + '/groupSessions/' + $sessionId + '/groups/' + $groupId + '/drawerUid').val() === auth.uid || $drawingId === 'phone_' + auth.uid)"
                }
              }
            }
          },
          "groupGuesses": {
            "$sessionId": {
              "$groupId": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid"
                }
              }
            }
          },
          "groupProgress": {
            "$sessionId": {
              "$groupId": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid"
                }
              }
            }
          },
          "groupPhone": {
            "$sessionId": {
              "$groupId": {
                "$uid": {
                  ".write": "auth != null && auth.uid === $uid"
                }
              }
            }
          }
        }
      }
    }
  }
}
